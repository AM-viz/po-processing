# ---------------------------------------------------------------------------
# AWS GovCloud Bedrock (inference)
# ---------------------------------------------------------------------------
AWS_REGION=us-gov-west-1
# Optional explicit Bedrock endpoint override (otherwise derived from region):
# BEDROCK_ENDPOINT_URL=

# Claude model / inference-profile ids (must be granted model access in GovCloud)
BEDROCK_SONNET_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_HAIKU_MODEL_ID=anthropic.claude-3-5-haiku-20241022-v1:0

# AWS credentials (omit if using an instance profile / role)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Inference tuning
BEDROCK_MAX_TOKENS=8192
BEDROCK_MAX_RETRIES=5
# Optional throttle (seconds) between calls; 0 disables.
BEDROCK_CALL_DELAY_SECONDS=0
# PDFs larger than this (bytes) skip Bedrock and use pdfplumber extraction.
BEDROCK_MAX_PDF_BYTES=4500000

# ---------------------------------------------------------------------------
# Storage (Databricks Volumes)
# ---------------------------------------------------------------------------
# Set to a Unity Catalog Volume path in production; leave unset for local dev
# (falls back to the package-local data/ and exemplary_data/ directories).
# VOLUME_BASE=/Volumes/<catalog>/<schema>/<volume>
